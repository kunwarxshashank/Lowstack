generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  name          String
  password      String
  avatar        String?
  university    String?
  subjects      subject[]
  posts         post[]
  userRole      Role      @default(USER)
  subscription  Json?     // Store subscription as plain object
  resetToken       String?  
  resetTokenExpiry DateTime?
  punya         Int       @default(0)  // Points earned by uploading notes
  comments      Comment[]
  reports       Report[]
  favourites    Favourite[]
}



model BranchConfig {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  branch_code     String   @unique
  branch_name     String
  logo            String?
  semester_count  Int      @default(8)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model subject {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  User          User?   @relation(fields: [userId], references: [id])
  userId        String? @db.ObjectId
  university    String?
  course_name   String
  semester_code String
  subject_code  String
  subject_name  String
  allowed_categories String[]
}

model post {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  User          User?    @relation(fields: [userId], references: [id])
  userId        String?  @db.ObjectId
  university    String?
  course_name   String
  semester_code String
  subject_code  String
  subject_name  String
  title         String
  description   String
  category      String?
  file_url      String?
  file_name     String?
  views         Int      @default(0)
  likes         Int      @default(0)
  dislikes      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  comments      Comment[]
  reports       Report[]
  favourites    Favourite[]
}

enum Role {
  USER
  ADMIN
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  User      User?    @relation(fields: [userId], references: [id])
  userId    String?  @db.ObjectId
  post      post     @relation(fields: [postId], references: [id])
  postId    String   @db.ObjectId
  createdAt DateTime @default(now())
}

model Report {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  reason      String
  description String?
  User        User?        @relation(fields: [userId], references: [id])
  userId      String?      @db.ObjectId
  post        post         @relation(fields: [postId], references: [id])
  postId      String       @db.ObjectId
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum ReportStatus {
  PENDING
  SOLVED
  REJECTED
}

model Favourite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  User      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  post      post     @relation(fields: [postId], references: [id])
  postId    String   @db.ObjectId
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}
